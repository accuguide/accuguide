{
  "name": "accuguide",
  "version": "2.3.2",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:all": "mprocs",
    "build:prod": "tsx scripts/analytics.ts && next build",
    "build:beta": "cp src/app/beta.robots.ts src/app/robots.ts && next build",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "assist": "biome check .",
    "assist:fix": "biome check --write .",
    "test:e2e": "cypress run",
    "test:component": "cypress run --component",
    "test:open": "cypress open",
    "db:start": "docker compose up",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx scripts/seed.ts",
    "db:stop": "docker compose down",
    "db:remove": "docker compose down -v",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "s3:push": "tsx src/lib/s3/push.ts",
    "ver:patch": "tsx scripts/version.ts patch",
    "ver:minor": "tsx scripts/version.ts minor",
    "ver:major": "tsx scripts/version.ts major",
    "ver:tag": "tsx scripts/tag.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.856.0",
    "@aws-sdk/s3-request-presigner": "^3.858.0",
    "@hookform/resolvers": "^5.2.1",
    "@mdx-js/loader": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@next/mdx": "^15.4.5",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-slot": "^1.2.3",
    "@types/mdx": "^2.0.13",
    "better-auth": "^1.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "critters": "^0.0.25",
    "dotenv": "^17.2.1",
    "drizzle-orm": "^0.44.5",
    "geist": "^1.4.2",
    "groq-sdk": "^0.30.0",
    "js-cookie": "^3.0.5",
    "lucide-react": "^0.536.0",
    "next": "15.5.2",
    "next-themes": "^0.4.6",
    "pg": "^8.16.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.61.1",
    "sonner": "^2.0.6",
    "tailwind-merge": "^3.3.1",
    "uuid": "^11.1.0",
    "zod": "^4.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.2",
    "@tailwindcss/postcss": "^4",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^24",
    "@types/pg": "^8.15.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cypress": "^14.5.3",
    "drizzle-kit": "^0.31.5",
    "mprocs": "^0.7.3",
    "tailwindcss": "^4",
    "tsx": "^4.20.3",
    "tw-animate-css": "^1.3.6",
    "typescript": "^5"
  },
  "engines": {
    "node": "=22",
    "npm": "=10"
  }
}
